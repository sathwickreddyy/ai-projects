# ─── Auth Mode ────────────────────────────────────────────────────────────────
# Controls how the backend calls Claude.
# cli     → uses `claude` CLI subprocess — only works when backend runs on HOST (not Docker)
# bedrock → uses AWS Bedrock (set AWS credentials below)
# api     → uses direct Anthropic API key — use this for Docker deployments
CLAUDE_AUTH_MODE=api

# ─── Direct API key (only needed when CLAUDE_AUTH_MODE=api) ──────────────────
ANTHROPIC_API_KEY=

# ─── AWS Bedrock (only needed when CLAUDE_AUTH_MODE=bedrock) ─────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-sonnet-4-5-v1

# ─── Postgres ─────────────────────────────────────────────────────────────────
POSTGRES_USER=arch
POSTGRES_PASSWORD=arch_secret
POSTGRES_DB=arch_platform
DATABASE_URL=postgresql+asyncpg://arch:arch_secret@postgres:5432/arch_platform

# ─── App ──────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me
ENVIRONMENT=development
PROJECTS_DIR=/projects
